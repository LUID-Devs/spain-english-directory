# Database Environment Variables
DB_HOST=localhost
DB_PORT=5432
DB_NAME=spain_english_directory
DB_USER=postgres
DB_PASSWORD=

# Admin API Key for claim management
ADMIN_API_KEY=your-secure-admin-api-key-here
ADMIN_EMAIL=admin@spainenglishdirectory.com

# Dashboard auth/session
AUTH_SESSION_SECRET=replace-with-a-strong-random-secret
DASHBOARD_LOGIN_PASSWORD=replace-with-strong-password

# SMTP Configuration for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@spainenglishdirectory.com
