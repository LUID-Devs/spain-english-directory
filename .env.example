# TaskLuid Frontend Environment Variables

# ============================================
# REQUIRED for Production
# ============================================

# API Base URL - MUST be set in production!
# This is the backend API URL that the frontend connects to
VITE_API_BASE_URL=https://api.taskluid.com

# AWS Cognito Configuration (Required for authentication)
VITE_COGNITO_DOMAIN=https://us-east-1spqxbs7w9.auth.us-east-1.amazoncognito.com
VITE_COGNITO_USER_POOL_ID=us-east-1_SpqXBs7w9
VITE_COGNITO_CLIENT_ID=your_cognito_client_id
VITE_COGNITO_REDIRECT_URI=https://taskluid.com/auth/callback
VITE_COGNITO_REGION=us-east-1

# ============================================
# Optional Configuration
# ============================================

# Alternative API URL (used as fallback)
# VITE_API_URL=https://api.taskluid.com

# ============================================
# DEVELOPMENT ONLY (DO NOT USE IN PRODUCTION)
# ============================================
# For local development, you can use these defaults:
# VITE_API_BASE_URL=http://localhost:8000
# VITE_COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
