generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId            Int       @id @default(autoincrement())
  email             String    @unique
  username          String?
  profilePictureUrl String?
  organizationId    Int
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  authoredTasks     Task[]    @relation("TaskAuthor")
  assignedTasks     Task[]    @relation("TaskAssignee")
  savedViews        SavedView[]
  inlineComments    InlineComment[]
  reviewRequestsSent    PRReviewRequest[] @relation("ReviewRequestedBy")
  reviewRequestsReceived PRReviewRequest[] @relation("ReviewRequestedFrom")

  @@index([organizationId])
  @@map("users")
}

model Project {
  id             Int       @id @default(autoincrement())
  name           String
  description    String?
  organizationId Int
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  tasks          Task[]
  workflowStates WorkflowState[]

  @@index([organizationId])
  @@map("projects")
}

model WorkflowState {
  id        Int     @id @default(autoincrement())
  name      String
  color     String?
  position  Int     @default(0)
  projectId Int

  // Relations
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("workflow_states")
}

model Task {
  id             Int       @id @default(autoincrement())
  title          String
  description    String?
  status         String    @default("To Do")
  priority       String?   // P0, P1, P2, P3, P4
  taskType       String?   @map("task_type") // Feature, Bug, Chore
  tags           String?
  startDate      DateTime? @map("start_date")
  dueDate        DateTime? @map("due_date")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  points         Int?
  triaged        Boolean   @default(false)
  isShared       Boolean   @default(false) @map("is_shared")
  archivedAt     DateTime? @map("archived_at")
  organizationId Int       @map("organization_id")

  // Foreign Keys
  projectId      Int       @map("project_id")
  authorUserId   Int       @map("author_user_id")
  assignedUserId Int?      @map("assigned_user_id")
  cycleId        Int?      @map("cycle_id")

  // Relations
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author         User      @relation("TaskAuthor", fields: [authorUserId], references: [userId])
  assignee       User?     @relation("TaskAssignee", fields: [assignedUserId], references: [userId])
  cycle          Cycle?    @relation(fields: [cycleId], references: [id])
  comments       Comment[]
  attachments    Attachment[]
  embeddings     TaskEmbedding[]

  @@index([organizationId])
  @@index([projectId])
  @@index([authorUserId])
  @@index([assignedUserId])
  @@index([status])
  @@index([priority])
  @@map("tasks")
}

model Cycle {
  id        Int      @id @default(autoincrement())
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tasks     Task[]

  @@map("cycles")
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  taskId    Int      @map("task_id")
  authorId  Int      @map("author_id")

  // Relations
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("comments")
}

model Attachment {
  id        Int      @id @default(autoincrement())
  filename  String
  url       String
  mimeType  String?  @map("mime_type")
  size      Int?
  createdAt DateTime @default(now()) @map("created_at")
  taskId    Int      @map("task_id")

  // Relations
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("attachments")
}

model SavedView {
  id             Int       @id @default(autoincrement())
  name           String
  filters        Json      // Stores AdvancedTaskFilter JSON
  isDefault      Boolean   @default(false) @map("is_default")
  isShared       Boolean   @default(false) @map("is_shared")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  organizationId Int       @map("organization_id")
  ownerId        Int       @map("owner_id")

  // Relations
  owner          User      @relation(fields: [ownerId], references: [userId], onDelete: Cascade)

  @@index([organizationId])
  @@index([ownerId])
  @@map("saved_views")
}

// ==================== GIT REVIEW MODELS ====================

model PRReview {
  id                        Int       @id @default(autoincrement())
  taskId                    Int       @map("task_id")
  prId                      Int       @map("pr_id")
  userId                    Int       @map("user_id")
  status                    String    // pending, reviewing, approved, changes_requested, merged
  notes                     String?
  checklist                 Json      // Array of { id, label, checked }
  reviewedAt                DateTime? @map("reviewed_at")
  reviewedByUserId          Int?      @map("reviewed_by_user_id")
  reviewedByUsername        String?   @map("reviewed_by_username")
  reviewedByProfilePictureUrl String? @map("reviewed_by_profile_picture_url")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  @@unique([taskId, prId, userId])
  @@index([taskId])
  @@index([prId])
  @@index([userId])
  @@map("pr_reviews")
}

model InlineComment {
  id          Int       @id @default(autoincrement())
  prId        Int       @map("pr_id")
  authorId    Int       @map("author_id")
  filePath    String    @map("file_path")
  lineNumber  Int       @map("line_number")
  commitId    String?   @map("commit_id")
  text        String
  replyToId   Int?      @map("reply_to_id")
  resolvedAt  DateTime? @map("resolved_at")
  resolvedBy  Int?      @map("resolved_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  author      User      @relation(fields: [authorId], references: [userId], onDelete: Cascade)
  replies     InlineComment[] @relation("CommentReplies")
  parent      InlineComment?  @relation("CommentReplies", fields: [replyToId], references: [id])

  @@index([prId])
  @@index([authorId])
  @@index([replyToId])
  @@map("inline_comments")
}

model PRReviewRequest {
  id               Int       @id @default(autoincrement())
  taskId           Int       @map("task_id")
  prId             Int       @map("pr_id")
  requestedById    Int       @map("requested_by_id")
  requestedFromId  Int       @map("requested_from_id")
  status           String    // pending, accepted, declined, completed
  message          String?
  dueDate          DateTime? @map("due_date")
  responseMessage  String?   @map("response_message")
  requestedAt      DateTime  @default(now()) @map("requested_at")
  respondedAt      DateTime? @map("responded_at")

  // Relations
  requestedBy      User      @relation("ReviewRequestedBy", fields: [requestedById], references: [userId], onDelete: Cascade)
  requestedFrom    User      @relation("ReviewRequestedFrom", fields: [requestedFromId], references: [userId], onDelete: Cascade)

  @@index([prId])
  @@index([requestedById])
  @@index([requestedFromId])
  @@index([status])
  @@map("pr_review_requests")
}

model AIReview {
  id            Int       @id @default(autoincrement())
  prId          Int       @map("pr_id")
  agentId       Int       @map("agent_id")
  agentName     String    @map("agent_name")
  status        String    // running, completed, failed
  summary       String
  findings      Json      // Array of findings
  options       Json?     // Review options
  errorMessage  String?   @map("error_message")
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")

  @@index([prId])
  @@index([agentId])
  @@index([status])
  @@map("ai_reviews")
}

model AIAgent {
  id            Int       @id @default(autoincrement())
  name          String
  description   String?
  capabilities  Json      // Array of capabilities
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("ai_agents")
}

// ==================== SEMANTIC SEARCH MODELS ====================

model TaskEmbedding {
  id            Int       @id @default(autoincrement())
  taskId        Int       @map("task_id")
  content       String    // The text that was embedded
  contentType   String    @map("content_type") // "title", "description", "comment"
  embedding     Unsupported("vector(384)") // pgvector extension
  modelName     String    @map("model_name") // Model used for embedding
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([contentType])
  @@map("task_embeddings")
}
