# Database
DATABASE_URL="postgresql://user:password@localhost:5432/taskluid?schema=public"

# JWT Secret for authentication
JWT_SECRET="your-secret-key-here"

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# OAuth Configuration for Third-Party Integrations
# Asana - https://app.asana.com/0/developer-console
ASANA_CLIENT_ID=""
ASANA_CLIENT_SECRET=""

# Linear - https://linear.app/settings/api
LINEAR_CLIENT_ID=""
LINEAR_CLIENT_SECRET=""

# GitHub - https://github.com/settings/applications/new
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Jira - https://developer.atlassian.com/console/myapps/
JIRA_CLIENT_ID=""
JIRA_CLIENT_SECRET=""

# Trello - https://trello.com/app-key
TRELLO_CLIENT_ID=""
TRELLO_CLIENT_SECRET=""

# Email Configuration (SMTP) - Optional, emails will be logged if not configured
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL="noreply@taskluid.com"

# Application URL for share links
APP_URL="https://app.taskluid.com"
